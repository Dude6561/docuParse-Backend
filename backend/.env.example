NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000

# ========================================================
# DATABASE - REQUIRED: Replace with your real connection string
# ========================================================
# Supabase (free): postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Neon (free):     postgresql://[user]:[password]@[host].neon.tech/neondb?sslmode=require
# Railway:         postgresql://postgres:[password]@[host].railway.app:5432/railway
# Local:           postgresql://postgres:postgres@localhost:5432/docextract
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docextract

# Supabase Storage (optional – documents still process without remote storage)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# AWS Textract (required for OCR processing)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET

# File upload
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,image/tiff
JOB_POLL_INTERVAL_MS=2000